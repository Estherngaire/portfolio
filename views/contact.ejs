<%- include('partials/header') %>
<% if (typeof success !== 'undefined') { %>
  <div class="bg-green-100 text-green-700 p-3 rounded mb-4">
    <%= success %>
  </div>
<% } %>

<% if (typeof error !== 'undefined') { %>
  <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
    <%= error %>
  </div>
<% } %>

<main class="bg-primary flex-grow flex items-center justify-center p-4">
 <div class="flex flex-col max-w-md">
    <h1 class="text-xl md:text-2xl font-bold p-3">Contact Me</h1>
    <p class="text-base md:text-lg font-semibold">Feel free to reach out to me.</p>
    <form action="/contact" method="POST" class="flex flex-col gap-2">
        <div class="grid grid-cols-[120px_1fr]">
            <label for="name" class="text-lg md:text-xl">Name</label>
            <input type="text" id="name" name="name" placeholder="Your Name" class="bg-NeutralLight py-1 rounded-md" required>
        </div>
        <div class="grid grid-cols-[120px_1fr]">
            <label for="email" class="text-lg md:text-xl">Email</label>
            <input type="email" id="email" name="email" class="bg-NeutralLight py-1 rounded-md" placeholder="Your Email" required>
        </div>
        <div class="grid grid-cols-[120px_1fr]">
         <label for="message" class="text-lg md:text-xl">Message</label>
           <textarea id="message" rows="3" name="message" placeholder="Your Message" class="bg-NeutralLight rounded-md" required></textarea>     
        </div>
        <button type="submit" class="bg-secondary text-neutralDark px-10 py-4 rounded self-center mt-3">Send Message</button>
    </form>
 </div>
 <script>
  const form = document.getElementById('contactForm');
  const button = form.querySelector('button');

  form.addEventListener('submit', () => {
    button.disabled = true;
    button.innerText = 'Sending message... please wait';
  });
</script>

</main>
<%- include('partials/footer') %>